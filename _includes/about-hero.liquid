{% comment %} Profile hero: LinkedIn-style card — banner + overlapping avatar + two-column details {% endcomment %}
<header class="hero">
  <div
    class="hero-banner"
    role="img"
    aria-label="Animated finite-element mesh coloured like a stress-contour plot, with governing equations of mechanics floating above it"
  >
    <canvas class="hero-fem" aria-hidden="true"></canvas>
    <div class="hero-eqns" aria-hidden="true"></div>
    <noscript>
      <span class="hero-fallback" style="background-image: url('{{ '/assets/img/banner.svg' | relative_url }}');"></span>
    </noscript>
  </div>

  {% comment %} Each piece below is an independent element — style/position them separately. {% endcomment %}
  <div class="hero-identity">
    {% if page.profile.image %}
      <div class="hero-avatar">
        <img
          src="{{ page.profile.image | prepend: '/assets/img/' | relative_url }}"
          alt="{{ site.title }}"
          loading="eager"
        >
      </div>
    {% endif %}

    <div class="hero-cols">
      <div class="hero-id-main">
        <h1 class="hero-name">{{ site.title }}</h1>
        {% if page.subtitle %}
          <p class="hero-headline">{{ page.subtitle }}</p>
        {% endif %}
        {% if page.facts %}
          <ul class="hero-meta">
            {% for fact in page.facts %}
              <li><i class="{{ fact.icon }}" aria-hidden="true"></i><span>{{ fact.text }}</span></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      {% if page.education %}
        <ul class="hero-education" aria-label="Education">
          {% for edu in page.education %}
            <li class="hero-edu">
              {% if edu.logo %}
                <img class="hero-edu__logo" src="{{ edu.logo | prepend: '/assets/img/' | relative_url }}" alt="" loading="lazy">
              {% else %}
                <span class="hero-edu__logo hero-edu__logo--ph"><i class="fa-solid fa-graduation-cap" aria-hidden="true"></i></span>
              {% endif %}
              <span class="hero-edu__name">{{ edu.name }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</header>
